<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="min-h-screen w-full bg-zinc-900 p-10 text-white">
        <div class="flex justify-end w-full">
            <a href="/logout" class="bg-red-500 hover:bg-red-700 text-white font-bold pb-2 pt-1 px-3 rounded-md">Logout</a>
        </div>
        <h1 class="text-3xl font-bold mb-3 px-2">Edit Post</h1>
        <form action="/edit/<%= post._id %>" method="post">
            <textarea name="content" placeholder="Write Something..." class="text-sm overflow-auto [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none] bg-transparent block w-1/3 p-4 resize-none border-2 border-zinc-800 rounded-md outline-none" id=""><%= post.content %></textarea>
            <input type="submit" class="bg-green-500 hover:bg-green-700 w-32 block font-bold py-2 px-4 rounded-full mt-4" value="Update">
        </form>
    </div>
</body>
</html>