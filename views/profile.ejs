<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="min-h-screen w-full bg-zinc-900 p-10 text-white">
        <div class="flex justify-end w-full">
            <a href="/logout" class="bg-red-500 hover:bg-red-700 text-white font-bold pb-2 pt-1 px-3 rounded-md">Logout</a>
        </div>
        <h1 class="text-3xl font-bold mb-1 px-2">Profile</h1>
        <h3 class="text-lg mb-4 px-2">Welcome, <%= user.name %>!</h3>
        <form action="/post" method="post">
            <textarea name="content" placeholder="Write Something..." class="text-sm overflow-auto [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none] bg-transparent block w-1/3 p-4 resize-none border-2 border-zinc-800 rounded-md outline-none" id=""></textarea>
            <input type="submit" class="bg-blue-500 hover:bg-blue-700 w-32 block font-bold py-2 px-4 rounded-full mt-4" value="Post">
        </form>
        <div class="posts mt-20">
            <h3 class="text-zinc-400 px-4">Your Posts</h3>
            <div class="postContainer mt-5 grid grid-cols-3 gap-4">
                <% if(user.posts.length > 0) { %>
                    <% user.posts.reverse().forEach(post => { %>
                        <div class="post p-4 rounded-lg border-2 border-zinc-800 flex flex-col h-full min-h-[150px]">
                            <h4 class="text-zinc-400">@<%= user.username %></h4>
                            <p class="px-[3px] pt-2 font-[500] flex-grow"><%= post.content %></p>
                            <small class="my-2 ml-[4px]"><%= post.likes.length %> likes</small>
                            <div class="btns flex justify-between items-center">
                                <div class="flex gap-3">
                                    <a href="/like/<%= post._id %>" class="text-blue-500 text-sm hover:text-blue-700">
                                        <%= post.likes.indexOf(user._id) === -1 ? "Like" : "Unlike" %>
                                    </a>
                                    <a href="/edit/<%= post._id %>" class="text-zinc-500 text-sm hover:text-zinc-700">Edit</a>
                                </div>
                                <a href="/delete/<%= post._id %>" class="text-red-500 text-sm hover:text-red-700">Delete</a>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <h4 class="text-zinc-500 px-4">No posts yet.</h4>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>